# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=authuser
DB_PASSWORD=authpass
DB_NAME=authdb

# Redis
REDIS_URL=redis://localhost:6379

# JWT — make these long random strings!
JWT_ACCESS_SECRET=your_super_secret_access_key_min_32_characters_long
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_characters_long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY_DAYS=30

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=noreply@authserver.com

# Security
BCRYPT_ROUNDS=12
MAX_FAILED_LOGINS=5
LOCKOUT_DURATION_MINUTES=15

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173